---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Empathetic Engagement - Precision Diagnostics">
	<main>
		<section class="hero">
			<div class="content">
				<h1>
					Bridging the gap in <span class="text-gradient"
						>Health Literacy & Compliance</span
					>
				</h1>
				<p class="subtitle">
					In India today, doctors have near-zero time to spend with
					each patient. Empathetic Engagement acts as your tireless
					diagnostic partner—translating complex medical data into
					clear, actionable intelligence so patients understand their
					health, and doctors can focus on care.
				</p>
				<div class="cta-group">
					<a href="/analyze" class="button primary"
						>Imaging Analysis</a
					>
					<a href="/doctor-assisted-ai" class="button secondary"
						>Doctor Assistant</a
					>
					<a href="/blood-analysis" class="button secondary"
						>Blood Analysis</a
					>
				</div>
			</div>
			<div class="visual">
				<!-- Placeholder for 3D visual or abstract medical scan animation -->
				<div class="scan-container">
					<div class="scan-line"></div>
					<div class="scan-object"></div>
				</div>
			</div>
		</section>

		<section class="mission">
			<div class="container">
				<h2>The Reality of Care</h2>
				<p>
					With overwhelmed clinics and overflowing waiting rooms, the
					critical moment of patient education is often lost. We
					ensure every patient receives an empathetic, thorough
					explanation of their diagnosis, improving adherence to
					treatment and bridging the vital gap between clinical
					findings and patient reality.
				</p>
			</div>
		</section>
	</main>
</Layout>

<style>
	main {
		color: var(--color-text-main);
		width: 100%;
	}

	.hero {
		display: flex;
		align-items: center;
		padding: 4rem 2rem;
		min-height: 80vh;
		background:
			radial-gradient(
				circle at top right,
				rgba(0, 212, 255, 0.05),
				transparent 40%
			),
			radial-gradient(
				circle at bottom left,
				rgba(0, 86, 179, 0.05),
				transparent 40%
			);
		position: relative;
		overflow: hidden;
	}

	.content {
		flex: 1;
		padding-right: 2rem;
		max-width: 600px;
		z-index: 10;
	}

	h1 {
		font-size: 3.5rem;
		line-height: 1.1;
		margin-bottom: 1.5rem;
	}

	.text-gradient {
		background: linear-gradient(
			135deg,
			var(--color-primary),
			var(--color-accent)
		);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		display: block;
	}

	.subtitle {
		font-size: 1.25rem;
		color: var(--color-text-muted);
		margin-bottom: 2.5rem;
		max-width: 50ch;
	}

	.cta-group {
		display: flex;
		gap: 1rem;
	}

	.button {
		padding: 0.75rem 1.5rem;
		border-radius: 50px;
		text-decoration: none;
		font-weight: 600;
		transition: all 0.3s ease;
	}

	.button.primary {
		background: var(--color-primary);
		color: #000;
	}

	.button.primary:hover {
		background: var(--color-accent);
		box-shadow: 0 0 20px rgba(0, 212, 255, 0.4);
	}

	.button.secondary {
		border: 1px solid var(--color-text-muted);
		color: var(--color-text-main);
	}

	.button.secondary:hover {
		border-color: var(--color-primary);
		color: var(--color-primary);
	}

	.visual {
		flex: 1;
		display: flex;
		justify-content: center;
		align-items: center;
		position: relative;
	}

	/* Abstract Scan Animation */
	.scan-container {
		width: 300px;
		height: 400px;
		border: 1px solid rgba(0, 212, 255, 0.2);
		border-radius: 20px;
		position: relative;
		background: rgba(0, 212, 255, 0.02);
		backdrop-filter: blur(5px);
		box-shadow: 0 0 30px rgba(0, 212, 255, 0.05);
	}

	.scan-line {
		width: 100%;
		height: 2px;
		background: var(--color-primary);
		position: absolute;
		top: 0;
		left: 0;
		animation: scan 3s infinite linear;
		box-shadow: 0 0 10px var(--color-primary);
	}

	.scan-object {
		/* Abstract representation of a body part or organ */
		width: 150px;
		height: 200px;
		background: linear-gradient(
			to bottom,
			rgba(0, 212, 255, 0.2),
			rgba(0, 86, 179, 0.2)
		);
		border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		filter: blur(20px);
	}

	@keyframes scan {
		0% {
			top: 0;
			opacity: 0;
		}
		10% {
			opacity: 1;
		}
		90% {
			opacity: 1;
		}
		100% {
			top: 100%;
			opacity: 0;
		}
	}

	.mission {
		background: #f8fafc; /* Light grey/off-white */
		padding: 4rem 2rem;
		text-align: center;
	}

	.mission h2 {
		font-size: 2.5rem;
		margin-bottom: 2rem;
		color: var(--color-text-main);
	}

	.mission p {
		font-size: 1.5rem;
		max-width: 800px;
		margin: 0 auto;
		color: var(--color-text-muted);
		line-height: 1.8;
	}

	@media (max-width: 768px) {
		.hero {
			flex-direction: column;
			text-align: center;
			padding-top: 6rem;
		}

		.content {
			padding-right: 0;
			margin-bottom: 3rem;
		}

		.text-gradient {
			display: inline;
		}

		.cta-group {
			justify-content: center;
		}
	}
</style>
